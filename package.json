{
  "name": "pnpm-workspaces",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "pnpm -r --parallel run dev",
    "dev:apps": "pnpm --filter \"./apps/*\" --parallel run dev",
    "dev:packages": "pnpm --filter \"./packages/*\" --parallel run dev",
    "build": "pnpm -r run build",
    "build:apps": "pnpm --filter \"./apps/*\" run build",
    "type-check": "pnpm -r exec tsc --noEmit",
    "type-check:react": "pnpm --filter react exec tsc --noEmit",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
